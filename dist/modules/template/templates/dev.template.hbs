<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width">
<title>[{{project}}] Déploiement</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background: #f0f2f5; color: #1a1a2e; }
  .wrapper { max-width: 680px; margin: 24px auto; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.12); }

  /* HEADER */
  .header { background: linear-gradient(135deg, #1a1a2e 0%, #16213e 60%, #0f3460 100%); padding: 28px 32px; }
  .header-top { display: flex; justify-content: space-between; align-items: flex-start; }
  .project-name { color: #e94560; font-size: 13px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; }
  .impact-badge { font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 20px; text-transform: uppercase; letter-spacing: 0.5px; }
  .impact-low { background: #1a472a; color: #52c41a; }
  .impact-medium { background: #3a2c0a; color: #faad14; }
  .impact-high { background: #3a0a0a; color: #ff4d4f; }
  .header h1 { color: #ffffff; font-size: 20px; font-weight: 700; margin-top: 10px; line-height: 1.3; }
  .header-meta { margin-top: 14px; display: flex; gap: 20px; flex-wrap: wrap; }
  .meta-item { color: rgba(255,255,255,0.65); font-size: 12px; }
  .meta-item strong { color: rgba(255,255,255,0.9); font-weight: 600; }

  /* BODY */
  .body { background: #ffffff; }

  /* AI SUMMARY */
  .ai-block { background: linear-gradient(135deg, #e8f4fd 0%, #eef6ff 100%); border-left: 4px solid #1890ff; padding: 18px 24px; margin: 0; }
  .ai-label { font-size: 11px; font-weight: 700; color: #1890ff; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; display: flex; align-items: center; gap: 6px; }
  .ai-text { font-size: 14px; color: #1d3557; line-height: 1.6; }

  /* SECTION */
  .section { padding: 24px 32px; border-bottom: 1px solid #f0f0f0; }
  .section:last-child { border-bottom: none; }
  .section-title { font-size: 11px; font-weight: 700; color: #8c8c8c; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
  .section-title .count { background: #f0f0f0; color: #595959; font-size: 11px; padding: 1px 7px; border-radius: 10px; }

  /* COMMITS */
  .commit-card { border: 1px solid #e8e8e8; border-radius: 8px; padding: 14px 16px; margin-bottom: 10px; background: #fafafa; }
  .commit-card:last-child { margin-bottom: 0; }
  .commit-message { font-size: 14px; font-weight: 600; color: #1a1a2e; margin-bottom: 8px; line-height: 1.4; }
  .commit-info { display: flex; gap: 12px; align-items: center; margin-bottom: 10px; }
  .commit-sha { font-family: 'SFMono-Regular', Consolas, monospace; font-size: 11px; background: #1a1a2e; color: #e94560; padding: 2px 8px; border-radius: 4px; }
  .commit-author { font-size: 12px; color: #8c8c8c; }
  .file-tags { display: flex; flex-wrap: wrap; gap: 4px; }
  .file-tag { font-family: monospace; font-size: 11px; background: #f0f5ff; color: #2f54eb; padding: 2px 7px; border-radius: 4px; border: 1px solid #d6e4ff; }
  .file-tag.added { background: #f6ffed; color: #389e0d; border-color: #b7eb8f; }
  .file-tag.more { background: #f0f0f0; color: #8c8c8c; border-color: #d9d9d9; }

  /* FILES TABLE */
  .files-table { width: 100%; border-collapse: collapse; font-size: 13px; }
  .files-table thead tr { background: #fafafa; }
  .files-table th { text-align: left; padding: 8px 12px; font-size: 11px; font-weight: 700; color: #8c8c8c; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 2px solid #f0f0f0; }
  .files-table td { padding: 7px 12px; border-bottom: 1px solid #f5f5f5; vertical-align: top; }
  .files-table tr:last-child td { border-bottom: none; }
  .folder-cell { font-family: monospace; font-size: 12px; color: #595959; white-space: nowrap; padding-right: 16px; }
  .folder-path { font-size: 11px; color: #bfbfbf; }
  .files-cell { font-family: monospace; font-size: 12px; color: #1d3557; }
  .files-row-alt { background: #fafafa; }

  /* CHECKPOINT */
  .checkpoint-block { background: #fffbe6; border: 1px solid #ffe58f; border-radius: 8px; padding: 14px 18px; }
  .checkpoint-block .label { font-size: 11px; font-weight: 700; color: #d48806; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
  .checkpoint-block p { font-size: 14px; color: #614700; }

  /* PR / RELEASE */
  .pr-card { border: 1px solid #d3f261; background: #fcffe6; border-radius: 8px; padding: 14px 18px; }
  .release-card { border: 1px solid #b7eb8f; background: #f6ffed; border-radius: 8px; padding: 14px 18px; }
  .card-title { font-size: 15px; font-weight: 700; color: #1a1a2e; margin-bottom: 6px; }
  .card-body { font-size: 13px; color: #595959; line-height: 1.5; }

  /* FOOTER */
  .footer { background: #f8f9fa; padding: 16px 32px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; }
  .footer-meta { font-size: 12px; color: #8c8c8c; }
  .footer-meta strong { color: #595959; font-family: monospace; }
  .footer-brand { font-size: 11px; color: #bfbfbf; }
</style>
</head>
<body>
<div class="wrapper">

  <!-- HEADER -->
  <div class="header">
    <div class="header-top">
      <span class="project-name">{{project}}</span>
      {{#if aiImpactLevel}}
      <span class="impact-badge impact-{{aiImpactLevel}}">
        {{#if (eq aiImpactLevel 'low')}}Impact faible{{/if}}
        {{#if (eq aiImpactLevel 'medium')}}Impact modéré{{/if}}
        {{#if (eq aiImpactLevel 'high')}}Impact élevé{{/if}}
      </span>
      {{/if}}
    </div>
    <h1>
      {{#if (eq eventType 'push')}}Push sur {{branch}}{{/if}}
      {{#if (eq eventType 'pull_request')}}PR mergée sur {{branch}}{{/if}}
      {{#if (eq eventType 'release')}}Release {{releaseTag}}{{/if}}
      {{#if (eq eventType 'manual')}}Déploiement manuel{{/if}}
    </h1>
    <div class="header-meta">
      <span class="meta-item">👤 <strong>{{author}}</strong></span>
      {{#if branch}}<span class="meta-item">🌿 <strong>{{branch}}</strong></span>{{/if}}
      {{#if commitCount}}<span class="meta-item">📦 <strong>{{commitCount}} commit(s)</strong></span>{{/if}}
      {{#if filesChangedCount}}<span class="meta-item">📁 <strong>{{filesChangedCount}} fichier(s)</strong></span>{{/if}}
    </div>
  </div>

  <div class="body">

    <!-- RÉSUMÉ IA -->
    {{#if aiDevSummary}}
    <div class="ai-block">
      <div class="ai-label">✦ Résumé IA</div>
      <div class="ai-text">{{aiDevSummary}}</div>
    </div>
    {{/if}}

    <!-- COMMITS -->
    {{#if commits}}
    <div class="section">
      <div class="section-title">
        Commits
        <span class="count">{{commitCount}}</span>
      </div>
      {{#each commits}}
      <div class="commit-card">
        <div class="commit-message">{{this.message}}</div>
        <div class="commit-info">
          <span class="commit-sha">{{this.id}}</span>
          <span class="commit-author">par {{this.author}}</span>
        </div>
        {{#if this.filesChanged.length}}
        <div class="file-tags">
          {{#each (limit this.filesChanged 6)}}
          <span class="file-tag">{{this}}</span>
          {{/each}}
          {{#if (gt this.filesChanged.length 6)}}
          <span class="file-tag more">+{{subtract this.filesChanged.length 6}} autres</span>
          {{/if}}
        </div>
        {{/if}}
      </div>
      {{/each}}
    </div>
    {{/if}}

    <!-- PULL REQUEST -->
    {{#if prTitle}}
    <div class="section">
      <div class="section-title">Pull Request</div>
      <div class="pr-card">
        <div class="card-title">#{{prNumber}} — {{prTitle}}</div>
        {{#if prBody}}<div class="card-body">{{prBody}}</div>{{/if}}
      </div>
    </div>
    {{/if}}

    <!-- RELEASE -->
    {{#if releaseTag}}
    <div class="section">
      <div class="section-title">Release</div>
      <div class="release-card">
        <div class="card-title">{{releaseTag}}{{#if releaseName}} — {{releaseName}}{{/if}}</div>
        {{#if releaseBody}}<div class="card-body">{{releaseBody}}</div>{{/if}}
      </div>
    </div>
    {{/if}}

    <!-- FICHIERS PAR DOSSIER -->
    {{#if filesGroupedByFolder}}
    <div class="section">
      <div class="section-title">
        Fichiers modifiés
        <span class="count">{{filesChangedCount}}</span>
      </div>
      <table class="files-table">
        <thead>
          <tr>
            <th>Dossier</th>
            <th>Fichiers</th>
          </tr>
        </thead>
        <tbody>
          {{#each filesGroupedByFolder}}
          <tr {{#if @odd}}class="files-row-alt"{{/if}}>
            <td class="folder-cell">📂 {{this.folder}}</td>
            <td class="files-cell">{{join this.files ", "}}</td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>
    {{/if}}

    <!-- CHECKPOINT -->
    {{#if checkpoint}}
    <div class="section">
      <div class="section-title">Checkpoint — Reprise</div>
      <div class="checkpoint-block">
        <div class="label">📌 Point de reprise</div>
        <p>{{checkpoint}}</p>
      </div>
    </div>
    {{/if}}

  </div><!-- /body -->

  <!-- FOOTER -->
  <div class="footer">
    <div class="footer-meta">
      Branche : <strong>{{branch}}</strong>
      {{#if commitSha}} &nbsp;·&nbsp; SHA : <strong>{{commitSha}}</strong>{{/if}}
      {{#if progress}} &nbsp;·&nbsp; Progression : <strong>{{progress}}</strong>{{/if}}
    </div>
    <div class="footer-brand">ProjectPulse · Notification automatique</div>
  </div>

</div>
</body>
</html>
