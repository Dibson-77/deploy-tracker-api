<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width">
<title>[{{project}}] Nouvelle mise à jour</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; background: #f0f2f5; color: #1a1a2e; }
  .wrapper { max-width: 620px; margin: 24px auto; border-radius: 12px; overflow: hidden; box-shadow: 0 4px 24px rgba(0,0,0,0.12); }

  /* HEADER */
  .header { background: linear-gradient(135deg, #198754 0%, #0f5132 60%, #052c16 100%); padding: 28px 32px; text-align: center; }
  .header-badge { display: inline-block; background: rgba(255,255,255,0.15); color: rgba(255,255,255,0.85); font-size: 11px; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; padding: 4px 12px; border-radius: 20px; margin-bottom: 12px; }
  .header h1 { color: #ffffff; font-size: 22px; font-weight: 700; line-height: 1.3; }
  .header-sub { color: rgba(255,255,255,0.7); font-size: 13px; margin-top: 8px; }

  /* BODY */
  .body { background: #ffffff; }

  /* AI SUMMARY */
  .ai-block { background: linear-gradient(135deg, #e6f4ea 0%, #f0faf2 100%); border-left: 4px solid #198754; padding: 20px 24px; }
  .ai-label { font-size: 11px; font-weight: 700; color: #198754; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
  .ai-text { font-size: 15px; color: #1a3a2a; line-height: 1.7; }

  /* SECTION */
  .section { padding: 22px 32px; border-bottom: 1px solid #f0f0f0; }
  .section:last-child { border-bottom: none; }
  .section-title { font-size: 11px; font-weight: 700; color: #8c8c8c; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 14px; }

  /* CHANGES */
  .change-item { display: flex; align-items: flex-start; gap: 10px; padding: 10px 14px; margin-bottom: 8px; background: #f6fff8; border: 1px solid #b7eb8f; border-radius: 8px; font-size: 14px; color: #1a3a2a; line-height: 1.5; }
  .change-item:last-child { margin-bottom: 0; }
  .change-icon { color: #52c41a; font-size: 16px; flex-shrink: 0; margin-top: 1px; }

  /* PROGRESS */
  .progress-wrap { background: #f0f0f0; border-radius: 12px; overflow: hidden; height: 28px; }
  .progress-fill { background: linear-gradient(90deg, #198754, #20c997); height: 100%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 13px; font-weight: 700; min-width: 40px; }

  /* NEXT STEP */
  .next-step { background: #e6f4fa; border: 1px solid #91d5ff; border-radius: 8px; padding: 14px 18px; }
  .next-step .label { font-size: 11px; font-weight: 700; color: #096dd9; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
  .next-step p { font-size: 14px; color: #003a8c; line-height: 1.5; }

  /* FOOTER */
  .footer { background: #f8f9fa; padding: 16px 32px; text-align: center; }
  .footer p { font-size: 12px; color: #8c8c8c; }
  .footer strong { color: #595959; }
</style>
</head>
<body>
<div class="wrapper">

  <!-- HEADER -->
  <div class="header">
    <div class="header-badge">{{project}}</div>
    <h1>Nouvelle mise à jour disponible</h1>
    <div class="header-sub">
      {{#if (eq eventType 'push')}}Push sur la branche <strong style="color:#fff">{{branch}}</strong>{{/if}}
      {{#if (eq eventType 'pull_request')}}Fusion de pull request sur <strong style="color:#fff">{{branch}}</strong>{{/if}}
      {{#if (eq eventType 'release')}}Nouvelle version <strong style="color:#fff">{{releaseTag}}</strong>{{/if}}
      {{#if (eq eventType 'manual')}}Déploiement manuel{{/if}}
    </div>
  </div>

  <div class="body">

    <!-- RÉSUMÉ IA -->
    {{#if aiUserSummary}}
    <div class="ai-block">
      <div class="ai-label">✦ Ce qui a changé</div>
      <div class="ai-text">{{aiUserSummary}}</div>
    </div>
    {{else if userMessage}}
    <div class="ai-block">
      <div class="ai-label">Information</div>
      <div class="ai-text">{{userMessage}}</div>
    </div>
    {{/if}}

    <!-- CE QUI CHANGE POUR VOUS -->
    {{#if userChanges}}
    <div class="section">
      <div class="section-title">Ce qui change pour vous</div>
      {{#each userChanges}}
      <div class="change-item">
        <span class="change-icon">✓</span>
        <span>{{this}}</span>
      </div>
      {{/each}}
    </div>
    {{/if}}

    <!-- PROGRESSION -->
    {{#if progress}}
    <div class="section">
      <div class="section-title">Progression du projet</div>
      <div class="progress-wrap">
        <div class="progress-fill" style="width: {{progress}}">{{progress}}</div>
      </div>
    </div>
    {{/if}}

    <!-- PROCHAINE ÉTAPE -->
    {{#if nextStep}}
    <div class="section">
      <div class="next-step">
        <div class="label">🔜 Prochaine étape</div>
        <p>{{nextStep}}</p>
      </div>
    </div>
    {{/if}}

  </div><!-- /body -->

  <!-- FOOTER -->
  <div class="footer">
    <p>Notification automatique — <strong>ProjectPulse</strong></p>
  </div>

</div>
</body>
</html>
